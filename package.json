{
  "name": "mind",
  "version": "1.2.1",
  "module": "cli/src/mind.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "bun test cli/test web/test",
    "test:cli": "bun test cli/test",
    "test:web": "bun test web/test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,js,json,css,md}\"",
    "format:check": "prettier --check .",
    "prepare": "husky install"
  },
  "lint-staged": {
    "*.{ts,js,json,css,md}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{ts,js}": [
      "tsc --noEmit"
    ]
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ansi-styles": "^6.2.3",
    "bun-style": "^0.3.2",
    "zod": "^4.3.6"
  }
}
