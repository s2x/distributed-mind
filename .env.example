# ═══════════════════════════════════════════════════════════════════════════════
# mind — Persistent memory for agents and humans
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Storage ────────────────────────────────────────────────────────────────────

# Directory where the SQLite database (mind.db) is stored.
# Default: ./data (relative to project root)
# MIND_DATA_DIR=./data

# Full path to the SQLite database file (overrides MIND_DATA_DIR + mind.db).
# Useful for testing with temporary databases.
# MIND_DB_PATH=/tmp/mind-test.db

# ─── RAG / Semantic Search (optional) ─────────────────────────────────────────

# Enable semantic search with OpenAI embeddings.
# When true, memories get a 1536-dim embedding stored in SQLite.
# Search blends FTS results with cosine similarity scores.
# Requires OPENAI_API_KEY to be set.
# MIND_RAG=true

# OpenAI API key for embeddings (text-embedding-3-small model).
# Get yours at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
